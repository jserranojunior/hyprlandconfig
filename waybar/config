    },
    "modules": [
      "custom/browser",
      "custom/file_manager",
      "custom/tty",
      "custom/steam",
      "custom/vscode",
      "custom/youtubemusic"
    ]
  },
  "custom/youtubemusic": {
    "format": "’óå ",
    "on-click": "flatpak run --command=brave com.brave.Browser --profile-directory=Default --app-id=cinhimbnkkaeohfgghhklpknlkffjgod",
    "tooltip": true,
    "tooltip-format": "Launch YouTube Music"
  },
  "custom/file_manager": {
    "format": "’āģ ",
