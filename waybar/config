{
  "height": 42,
  "layer": "top",
  "exclusive": true,
  "passthrough": false,
  "position": "top",
  "spacing": 3,
  "fixed-center": true,
  "ipc": {
    "enabled": true,
    "socket": "/tmp/hyprland.sock"
  },
  "margin-top": 3,
  "margin-left": 8,
  "margin-right": 8,
  "modules-left": [
    "hyprland/workspaces"
  ],
  "modules-center": [
    "group/app_drawer"
  ],
  "modules-right": [
    "custom/swaync",
    "clock",
    "network",
    "tray",
    "pulseaudio",
    "bluetooth",
    "custom/separator#dot-line",
    "custom/warp",
    "custom/separator#dot-line",
    "custom/updates",
    "custom/separator#dot-line",
    "custom/logout"
  ],
  "hyprland/workspaces": {
    "active-only": false,
    "all-outputs": true,
    "format": "{icon}",
    "show-special": false,
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "persistent-workspaces": {
      "*": 5
    },
    "format-icons": {
      "active": "’åÆ",
      "default": "’äī"
    }
  },
  "custom/warp": {
    "format": "{} ¾░¢é",
    "interval": 10,
    "return-type": "json",
    "exec": "status=$(warp-cli status | grep -oE 'Connected|Disconnected'); if [ \"$status\" = \"Connected\" ]; then echo '{\"text\": \"ON\", \"class\": \"connected\", \"tooltip\": \"WARP Connected\"}'; else echo '{\"text\": \"OFF\", \"class\": \"disconnected\", \"tooltip\": \"WARP Disconnected\"}'; fi",
    "on-click": "status=$(warp-cli status | grep -oE 'Connected|Disconnected'); if [ \"$status\" = \"Connected\" ]; then warp-cli disconnect; else warp-cli connect; fi",
    "tooltip": true
},
  "custom/updates": {
    "format": "Ō¤│ {}",
"exec": "echo $(( $(checkupdates | wc -l) + $(yay -Qua | wc -l) + $(flatpak remote-ls --updates | wc -l) ))",
    "tooltip": false,
    "interval": 1800,
"on-click": "kitty -e bash -c 'yay -Syu --noconfirm && flatpak update -y && echo \"Sistema Atualizado!\"; read -n 1; exec bash'"  },
