#!/bin/bash

# ==========================================
# 🚀 INSTALAÇÃO DE PACOTES (AUR - yay)
# ==========================================

yay -S --needed \
  hyprlock \        # Tela de bloqueio para Hyprland
  noctalia-shell \  # Shell/tema customizado para Wayland
  hypridle \        # Gerenciamento de inatividade (lock automático, etc.)

  grimblast \       # Ferramenta de screenshot para Wayland

  wl-clipboard \    # Clipboard (copiar/colar no Wayland) - Usando para screeshot
  playerctl \       # Controle de mídia via terminal

  polkit-kde \      # Autenticação gráfica (permissões de sistema)

  htop \            # Monitor de processos
  fzf \             # Busca fuzzy (ótimo para terminal/scripts)

  blueman \         # Interface gráfica para Bluetooth

  qt6-5compat \     # Compatibilidade com apps Qt5
  qt6-declarative \ # Suporte QML (Qt)
  qt6-svg \         # Suporte a SVG (Qt)

  mission-center    # Monitor de sistema com interface gráfica

# ==========================================
# 📦 PACOTES OFICIAIS (PACMAN)
# ==========================================

sudo pacman -S --needed \
  thunar \                      # Gerenciador de arquivos
  kitty \                       # Terminal moderno
  sddm \                        # Display manager (login gráfico)
  hyprland \                    # Window manager Wayland
  xdg-desktop-portal-hyprland \ # Integração com apps (Wayland portal)
  gnome-disk-utility \          # Gerenciar discos/partições
  pacman-contrib \              # Ferramentas extras do pacman

  gvfs \ gvfs-afc \ gvfs-gphoto2 \ gvfs-mtp \ gvfs-nfs \ gvfs-smb \ # Montagem automática
  udisks2 \                    # Gerenciamento de dispositivos
  thunar-volman \              # Automount no Thunar

  ttf-jetbrains-mono-nerd      # Fonte Nerd Font (programação)

# ==========================================
# 📦 FLATPAK (OPCIONAL)
# ==========================================

flatpak install -y flathub io.missioncenter.MissionCenter

# ==========================================
# 📦 GERENCIADORES (OPCIONAL)
# ==========================================

yay -S --needed dnfdragora easyflatpak

# ==========================================
# ⚙️ CONFIGURAR HYPRLAND NO SDDM
# ==========================================

echo "Criando sessão do Hyprland..."

sudo mkdir -p /usr/share/wayland-sessions

sudo bash -c 'cat > /usr/share/wayland-sessions/hyprland.desktop <<EOF
[Desktop Entry]
Name=Hyprland
Comment=An Intelligent Dynamic Tiling Wayland Compositor
Exec=Hyprland
Type=Application
EOF'

# ==========================================
# ⚙️ CONFIGURAR SDDM
# ==========================================

echo "Configurando SDDM..."

sudo bash -c 'cat > /etc/sddm.conf <<EOF
[General]
DisplayServer=wayland
Session=hyprland.desktop

[Theme]
Current=simple-sddm-2
EOF'

# ==========================================
# 🎨 INSTALAR TEMA SDDM
# ==========================================

echo "Instalando tema do SDDM..."

cd /usr/share/sddm/themes/ || exit
sudo git clone https://github.com/JaKooLit/simple-sddm-2.git

# ==========================================
# 🚀 ATIVAR NO BOOT
# ==========================================

echo "Ativando SDDM no boot..."

sudo systemctl enable sddm
sudo systemctl set-default graphical.target

# ==========================================
# 🔒 SCRIPT DE LOCK AUTOMÁTICO
# ==========================================

echo "Configurando script de lock..."

PROFILE_FILE="$HOME/.profile"

if ! grep -q "inactivity_lock.sh" "$PROFILE_FILE"; then
  echo 'exec --no-startup-id ~/.config/hyprlandconfig/NewConfigs/scripts/inactivity_lock.sh' >> "$PROFILE_FILE"
fi

# ==========================================
# ✅ FINALIZAÇÃO
# ==========================================

echo "=========================================="
echo "✅ Setup concluído!"
echo "👉 Reinicie o sistema para aplicar tudo"
echo "=========================================="